{
  "version": 4,
  "configurations": [
    {
      "name": "DevContainer Linux",
      "compilerPath": "/usr/bin/gcc",
      "intelliSenseMode": "linux-gcc-x64",
      "cStandard": "gnu17",
      "cppStandard": "gnu++17",
      "defines": [
        "_GNU_SOURCE",
        "_DEFAULT_SOURCE"
      ],
      "includePath": [
        "${workspaceFolder}/**",
        "/usr/include",
        "/usr/include/x86_64-linux-gnu",
        "/usr/local/include"
      ],
      "systemIncludePath": [
        "/usr/include",
        "/usr/include/x86_64-linux-gnu",
        "/usr/local/include"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}/**",
          "/usr/include",
          "/usr/include/x86_64-linux-gnu",
          "/usr/local/include"
        ],
        "limitSymbolsToIncludedHeaders": true
      ]
    }
  ]
}
